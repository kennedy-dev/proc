# ============================================================
#  Gov Opportunity Scout — environment
#  Copy to ".env" and fill in. Never commit the real .env.
# ============================================================

# Timezone used by n8n schedules and Postgres (IANA name).
TZ=Africa/Nairobi

# ---- Postgres (n8n's database) ----
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=n8n

# ---- n8n ----
# Generate once:  openssl rand -hex 32
# Keep it stable forever — it encrypts your stored credentials.
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# Local defaults. For production behind the Caddy proxy, set:
#   N8N_HOST=n8n.example.org
#   N8N_PROTOCOL=https
#   N8N_PUBLIC_URL=https://n8n.example.org/
#   N8N_SECURE_COOKIE=true
#   N8N_PROXY_HOPS=1
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PUBLIC_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false
N8N_PROXY_HOPS=0

# ---- SearXNG ----
# Public base URL of the SearXNG instance (used for absolute links only).
# n8n calls SearXNG privately at http://searxng:8080 (set in docker-compose.yml).
SEARXNG_BASE_URL=http://localhost:8080/

# ---- Production reverse proxy (only read when using: --profile proxy) ----
# DNS A/AAAA record for this name must point at this host; Caddy auto-fetches TLS.
N8N_DOMAIN=n8n.example.org
